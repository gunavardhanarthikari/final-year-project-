# TrueFace AI Environment Configuration
# Copy this file to .env and fill in your details

# Database Configuration
# ----------------------
# For Local Development (SQLite):
# SQLALCHEMY_DATABASE_URI=sqlite:///trueface.db

# For Production/Global Sync (PostgreSQL):
# Get your URI from Supabase or Neon.tech
DATABASE_URL=postgresql://user:password@host:port/database


# Email Alert Configuration (SMTP)
# -------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
ALERT_RECIPIENTS=admin-email@example.com


# Security
# --------
SECRET_KEY=generate-a-random-string-here
